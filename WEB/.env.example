# Public URL of the Next app (used for links; optional for local)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API base URL for the Axios client (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1

# Set to "true" only for local UI demos without a running API
NEXT_PUBLIC_USE_MOCKS=false

# Optional: tenantId stored in the client when using "Use mock account" (NEXT_PUBLIC_USE_MOCKS=true).
# Must match a seeded tenant if you call the real API afterward. Default in code matches API seed default.
# NEXT_PUBLIC_TENANT_ID=
