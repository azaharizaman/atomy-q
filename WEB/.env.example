# Public URL of the Next app (used for links and smoke validation)
NEXT_PUBLIC_APP_URL=https://alpha.example.com

# API base URL for the Axios client (no trailing slash). Must include /api/v1.
NEXT_PUBLIC_API_URL=https://api.alpha.example.com/api/v1

# Staging and alpha validation must run with mocks disabled.
NEXT_PUBLIC_USE_MOCKS=false

# Public bootstrap mirror of the global AI switch.
# Default to off so environments do not make live AI status/provider calls
# until operator configuration is intentionally enabled.
# The API status contract remains the source of truth once loaded.
# Set NEXT_PUBLIC_AI_MODE=provider only after API/provider configuration is present.
# off = AI disabled globally, provider = live Hugging Face-backed mode,
# deterministic = diagnostic/manual fallback mode.
NEXT_PUBLIC_AI_MODE=off

# Public path for the AI status contract exposed by the API.
# The UI can query this to distinguish config-disabled AI from runtime outages.
NEXT_PUBLIC_AI_STATUS_PATH=/api/v1/ai/status

# Optional label for operator-facing diagnostics or UI copy.
# Only meaningful when NEXT_PUBLIC_AI_MODE=provider.
NEXT_PUBLIC_AI_PROVIDER_NAME=huggingface

# Optional: deployed WEB hostname for manual or Playwright smoke validation.
# PLAYWRIGHT_BASE_URL=https://alpha.example.com

# Local-only mock tenant override for "Use mock account" flows.
# Keep unset in staging. If you enable NEXT_PUBLIC_USE_MOCKS=true locally,
# the tenantId must match a seeded tenant before you call the real API.
# NEXT_PUBLIC_TENANT_ID=
