        "azaharizaman/nexus-compliance-operations": "*@dev",
        "azaharizaman/nexus-connectivity-operations": "*@dev",
        "azaharizaman/nexus-connector": "*@dev",
        "azaharizaman/nexus-crypto": "*@dev",
        "azaharizaman/nexus-currency": "*@dev",
        "azaharizaman/nexus-data-exchange-operations": "*@dev",
        "azaharizaman/nexus-document": "*@dev",
        "azaharizaman/nexus-event-stream": "*@dev",
        "azaharizaman/nexus-export": "*@dev",
        "azaharizaman/nexus-feature-flags": "*@dev",
        "azaharizaman/nexus-idempotency": "*@dev",
        "azaharizaman/nexus-identity": "*@dev",
        "azaharizaman/nexus-identity-operations": "*@dev",
        "azaharizaman/nexus-insight-operations": "*@dev",
        "azaharizaman/nexus-intelligence-operations": "*@dev",
        "azaharizaman/nexus-laravel-approval-operations-adapter": "*@dev",
        "azaharizaman/nexus-laravel-idempotency-adapter": "*@dev",
        "azaharizaman/nexus-laravel-identity-adapter": "*@dev",
        "azaharizaman/nexus-laravel-notifier-adapter": "*@dev",
        "azaharizaman/nexus-laravel-setting-adapter": "*@dev",
        "azaharizaman/nexus-laravel-sourcing-adapter": "*@dev",
        "azaharizaman/nexus-laravel-tenant-adapter": "*@dev",
        "azaharizaman/nexus-laravel-vendor-adapter": "*@dev",
        "azaharizaman/nexus-machine-learning": "*@dev",
        "azaharizaman/nexus-messaging": "*@dev",
        "azaharizaman/nexus-notifier": "*@dev",
        "azaharizaman/nexus-outbox": "*@dev",
        "azaharizaman/nexus-party": "*@dev",
        "azaharizaman/nexus-policy-engine": "*@dev",
        "azaharizaman/nexus-procurement": "*@dev",
        "azaharizaman/nexus-procurement-ml": "dev-main",
        "azaharizaman/nexus-procurement-operations": "*@dev",
        "azaharizaman/nexus-project": "*@dev",
        "azaharizaman/nexus-project-management-operations": "*@dev",
        "azaharizaman/nexus-query-engine": "*@dev",
        "azaharizaman/nexus-quotation-intelligence": "*@dev",
        "azaharizaman/nexus-reporting": "*@dev",
        "azaharizaman/nexus-sanctions": "*@dev",
        "azaharizaman/nexus-scheduler": "*@dev",
        "azaharizaman/nexus-sequencing": "*@dev",
        "azaharizaman/nexus-setting": "*@dev",
        "azaharizaman/nexus-settings-management": "*@dev",
        "azaharizaman/nexus-sourcing": "*@dev",
        "azaharizaman/nexus-sourcing-operations": "*@dev",
        "azaharizaman/nexus-sso": "*@dev",
        "azaharizaman/nexus-storage": "*@dev",
        "azaharizaman/nexus-task": "*@dev",
        "azaharizaman/nexus-tenant": "*@dev",
        "azaharizaman/nexus-tenant-operations": "*@dev",
        "azaharizaman/nexus-uom": "*@dev",
        "azaharizaman/nexus-vendor": "*@dev",
        "azaharizaman/nexus-workflow": "*@dev",
        "azaharizaman/nexus-metric-engine": "*@dev",
        "firebase/php-jwt": "^6.10",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "league/flysystem-aws-s3-v3": "^3.0"
    },
    "require-dev": {
        "dedoc/scramble": "^0.13.15",
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm --prefix ../WEB run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
