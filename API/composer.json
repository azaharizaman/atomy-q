{
    "name": "atomy/atomy-q-api",
    "type": "project",
    "description": "Atomy-Q Quote Comparison SaaS - Backend API",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../../../packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../../orchestrators/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../../adapters/Laravel/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "firebase/php-jwt": "^6.10",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "league/flysystem-aws-s3-v3": "^3.0",
        "azaharizaman/nexus-aml-compliance": "*@dev",
        "nexus/approval-operations": "*@dev",
        "azaharizaman/nexus-audit-logger": "*@dev",
        "azaharizaman/nexus-common": "*@dev",
        "azaharizaman/nexus-compliance": "*@dev",
        "nexus/compliance-operations": "*@dev",
        "nexus/connectivity-operations": "*@dev",
        "azaharizaman/nexus-connector": "*@dev",
        "azaharizaman/nexus-crypto": "*@dev",
        "azaharizaman/nexus-currency": "*@dev",
        "nexus/data-exchange-operations": "*@dev",
        "azaharizaman/nexus-document": "*@dev",
        "azaharizaman/nexus-event-stream": "*@dev",
        "azaharizaman/nexus-export": "*@dev",
        "azaharizaman/nexus-feature-flags": "*@dev",
        "azaharizaman/nexus-idempotency": "*@dev",
        "azaharizaman/nexus-identity": "*@dev",
        "nexus/identity-operations": "*@dev",
        "nexus/insight-operations": "*@dev",
        "nexus/intelligence-operations": "*@dev",
        "azaharizaman/nexus-laravel-approval-operations-adapter": "*@dev",
        "azaharizaman/nexus-laravel-idempotency-adapter": "*@dev",
        "azaharizaman/nexus-laravel-identity-adapter": "*@dev",
        "azaharizaman/nexus-laravel-notifier-adapter": "*@dev",
        "azaharizaman/nexus-laravel-setting-adapter": "*@dev",
        "azaharizaman/nexus-laravel-sourcing-adapter": "*@dev",
        "azaharizaman/nexus-laravel-tenant-adapter": "*@dev",
        "azaharizaman/nexus-machine-learning": "*@dev",
        "azaharizaman/nexus-messaging": "*@dev",
        "azaharizaman/nexus-notifier": "*@dev",
        "azaharizaman/nexus-outbox": "*@dev",
        "azaharizaman/nexus-party": "*@dev",
        "azaharizaman/nexus-policy-engine": "*@dev",
        "azaharizaman/nexus-procurement": "*@dev",
        "nexus/procurement-operations": "*@dev",
        "azaharizaman/nexus-project": "*@dev",
        "nexus/project-management-operations": "*@dev",
        "azaharizaman/nexus-query-engine": "*@dev",
        "nexus/quotation-intelligence": "*@dev",
        "azaharizaman/nexus-reporting": "*@dev",
        "azaharizaman/nexus-sanctions": "*@dev",
        "azaharizaman/nexus-scheduler": "*@dev",
        "azaharizaman/nexus-sequencing": "*@dev",
        "azaharizaman/nexus-setting": "*@dev",
        "nexus/settings-management": "*@dev",
        "azaharizaman/nexus-sourcing": "*@dev",
        "nexus/sourcing-operations": "*@dev",
        "azaharizaman/nexus-sso": "*@dev",
        "azaharizaman/nexus-storage": "*@dev",
        "azaharizaman/nexus-task": "*@dev",
        "azaharizaman/nexus-tenant": "*@dev",
        "nexus/tenant-operations": "*@dev",
        "azaharizaman/nexus-uom": "*@dev",
        "azaharizaman/nexus-vendor": "*@dev",
        "azaharizaman/nexus-vendor-laravel-adapter": "*@dev",
        "azaharizaman/nexus-workflow": "*@dev"
    },
    "require-dev": {
        "dedoc/scramble": "^0.13.15",
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Nexus\\ProcurementML\\": "../../../packages/ProcurementML/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "nexus/laravel-approval-operations-adapter"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
