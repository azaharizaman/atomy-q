APP_ENV=local
APP_URL=http://localhost:8000
APP_KEY=

# CORS: edit config/cors.php allowed_origins for deployed WEB origins.

# Mail (password reset and future notifications)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=${APP_NAME}

# Shown in exported OpenAPI info.version (Scramble)
# API_VERSION=0.1.0

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=atomy_dev
DB_USERNAME=postgres
DB_PASSWORD=secret

# Required for auth; use e.g. base64:$(openssl rand -base64 32) for production
JWT_SECRET=base64:test-secret-for-local-dev-atomy-q-jwt-32bytes=
JWT_TTL=60
JWT_REFRESH_TTL=120
JWT_ALGO=HS256
JWT_ISSUER=atomy-q

REDIS_URL=redis://localhost:6379/0

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-bucket-name
AWS_URL=http://localhost:9000
AWS_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINTS=true

ATOMY_DEFAULT_PER_PAGE=25
ATOMY_MAX_PER_PAGE=100
ATOMY_MAX_UPLOAD_MB=50
ATOMY_MFA_DEVICE_TRUST_DAYS=30
ATOMY_APPROVAL_SLA_HOURS=48
ATOMY_APPROVAL_MAX_SNOOZE_HOURS=72
ATOMY_MIN_VENDORS_FINAL=2
ATOMY_MIN_VENDORS_PREVIEW=1
ATOMY_CONFIDENCE_THRESHOLD=0.7
ATOMY_SEED_TENANT_ID=

# Projects / Tasks API (WEB lists and detail pages call these; when false, routes return 404)
FEATURE_PROJECTS_ENABLED=true
FEATURE_TASKS_ENABLED=true
