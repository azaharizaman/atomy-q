APP_NAME=AtomyQ
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Database (Postgres) ---
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Redis ---
REDIS_CLIENT=predis
REDIS_URL=redis://localhost:6379

# --- Cache / Session / Queue ---
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# --- JWT ---
JWT_SECRET=change-me-in-production
JWT_TTL=60
JWT_REFRESH_TTL=20160

# --- File Storage ---
FILESYSTEM_DISK=local

# --- Mail ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@atomy-q.example"
MAIL_FROM_NAME="${APP_NAME}"
