# App
APP_ENV=staging
APP_DEBUG=false
APP_NAME="Atomy-Q API"
APP_URL=https://api.alpha.example.com
APP_KEY=
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=file
APP_PREVIOUS_KEYS=

# Authentication
AUTH_GUARD=web
AUTH_MODEL=App\Models\User
AUTH_PASSWORD_BROKER=users
AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
AUTH_PASSWORD_TIMEOUT=10800

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_CONNECTION=
SESSION_TABLE=sessions
SESSION_STORE=
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# CORS: edit config/cors.php allowed_origins for deployed WEB origins.

# Database
DB_CONNECTION=pgsql
DB_HOST=db.alpha.example.com
DB_PORT=5432
DB_DATABASE=atomy_alpha
DB_USERNAME=atomy_alpha
DB_PASSWORD=replace-me
DB_URL=
DB_SSLMODE=prefer

# Queue / Cache
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=database-uuids
CACHE_STORE=redis
CACHE_PREFIX=atomy-alpha-cache-
DB_CACHE_CONNECTION=pgsql
DB_CACHE_TABLE=cache
DB_CACHE_LOCK_CONNECTION=pgsql
DB_CACHE_LOCK_TABLE=cache_locks
DB_QUEUE_CONNECTION=pgsql
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90
REDIS_CLIENT=phpredis
REDIS_CLUSTER=redis
REDIS_PREFIX=atomy-alpha-database-
REDIS_URL=redis://redis.alpha.example.com:6379/0
REDIS_HOST=redis.alpha.example.com
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000
REDIS_PERSISTENT=false
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90

# JWT
JWT_SECRET=base64:replace-me-with-a-real-secret
JWT_TTL=60
JWT_REFRESH_TTL=120
JWT_ALGO=HS256
JWT_ISSUER=atomy-q

# Storage
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=atomy-q
AWS_URL=http://localhost:9000
AWS_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_USE_PATH_STYLE_ENDPOINTS=true

# AI runtime
# Alpha is AI-first: provider-backed AI is the default target posture.
# Modes: off = globally disabled, provider = real selected-provider endpoints,
# deterministic = manual/diagnostic fallback mode.
AI_MODE=provider
AI_PROVIDER=openrouter
AI_PROVIDER_NAME=openrouter

# Shared provider defaults. Per-endpoint auth/timeout values can override these.
AI_DEFAULT_AUTH_TOKEN=
AI_DEFAULT_TIMEOUT_SECONDS=60
AI_DEFAULT_RETRY_ATTEMPTS=2
AI_DEFAULT_RETRY_BACKOFF_MS=500

# Use dedicated managed inference endpoints per capability group.
# Document intelligence: quote upload, reparse, commercial terms extraction.
AI_DOCUMENT_ENDPOINT=
AI_DOCUMENT_AUTH_TOKEN=
AI_DOCUMENT_TIMEOUT_SECONDS=120
AI_DOCUMENT_MODEL_ID=
AI_DOCUMENT_MODEL_REVISION=

# Normalization intelligence: mapping, taxonomy, UOM normalization, conflict hints.
AI_NORMALIZATION_ENDPOINT=
AI_NORMALIZATION_AUTH_TOKEN=
AI_NORMALIZATION_TIMEOUT_SECONDS=60
AI_NORMALIZATION_MODEL_ID=
AI_NORMALIZATION_MODEL_REVISION=

# Sourcing recommendation intelligence: shortlist ranking and rationale.
AI_SOURCING_RECOMMENDATION_ENDPOINT=
AI_SOURCING_RECOMMENDATION_AUTH_TOKEN=
AI_SOURCING_RECOMMENDATION_TIMEOUT_SECONDS=45
AI_SOURCING_RECOMMENDATION_MODEL_ID=
AI_SOURCING_RECOMMENDATION_MODEL_REVISION=

# Comparison + award intelligence: overlays, anomaly explanations, debrief drafting.
AI_COMPARISON_AWARD_ENDPOINT=
AI_COMPARISON_AWARD_AUTH_TOKEN=
AI_COMPARISON_AWARD_TIMEOUT_SECONDS=60
AI_COMPARISON_AWARD_MODEL_ID=
AI_COMPARISON_AWARD_MODEL_REVISION=

# Insight intelligence: dashboard and RFQ summaries.
AI_INSIGHT_ENDPOINT=
AI_INSIGHT_AUTH_TOKEN=
AI_INSIGHT_TIMEOUT_SECONDS=45
AI_INSIGHT_MODEL_ID=
AI_INSIGHT_MODEL_REVISION=

# Governance intelligence: due diligence, risk, and governance narratives.
AI_GOVERNANCE_ENDPOINT=
AI_GOVERNANCE_AUTH_TOKEN=
AI_GOVERNANCE_TIMEOUT_SECONDS=45
AI_GOVERNANCE_MODEL_ID=
AI_GOVERNANCE_MODEL_REVISION=

# Legacy Hugging Face aliases remain supported during transition for endpoint and
# token/timeouts only. Prefer the generic AI_* variables above for new setups.
HF_PROVIDER_NAME=huggingface
HF_DEFAULT_AUTH_TOKEN=
HF_DEFAULT_TIMEOUT_SECONDS=60
HF_DEFAULT_RETRY_ATTEMPTS=2
HF_DEFAULT_RETRY_BACKOFF_MS=500
HF_DOCUMENT_ENDPOINT=
HF_DOCUMENT_AUTH_TOKEN=
HF_DOCUMENT_TIMEOUT_SECONDS=120
HF_DOCUMENT_MODEL_ID=
HF_DOCUMENT_MODEL_REVISION=
HF_NORMALIZATION_ENDPOINT=
HF_NORMALIZATION_AUTH_TOKEN=
HF_NORMALIZATION_TIMEOUT_SECONDS=60
HF_NORMALIZATION_MODEL_ID=
HF_NORMALIZATION_MODEL_REVISION=
HF_SOURCING_RECOMMENDATION_ENDPOINT=
HF_SOURCING_RECOMMENDATION_AUTH_TOKEN=
HF_SOURCING_RECOMMENDATION_TIMEOUT_SECONDS=45
HF_SOURCING_RECOMMENDATION_MODEL_ID=
HF_SOURCING_RECOMMENDATION_MODEL_REVISION=
HF_COMPARISON_AWARD_ENDPOINT=
HF_COMPARISON_AWARD_AUTH_TOKEN=
HF_COMPARISON_AWARD_TIMEOUT_SECONDS=60
HF_COMPARISON_AWARD_MODEL_ID=
HF_COMPARISON_AWARD_MODEL_REVISION=
HF_INSIGHT_ENDPOINT=
HF_INSIGHT_AUTH_TOKEN=
HF_INSIGHT_TIMEOUT_SECONDS=45
HF_INSIGHT_MODEL_ID=
HF_INSIGHT_MODEL_REVISION=
HF_GOVERNANCE_ENDPOINT=
HF_GOVERNANCE_AUTH_TOKEN=
HF_GOVERNANCE_TIMEOUT_SECONDS=45
HF_GOVERNANCE_MODEL_ID=
HF_GOVERNANCE_MODEL_REVISION=

# Legacy pre-Plan-1 quote-intelligence adapter vars. Keep these until the
# current runtime is migrated to the shared AI/Hugging Face contract above.
QUOTE_INTELLIGENCE_MODE=deterministic
QUOTE_INTELLIGENCE_LLM_PROVIDER=
QUOTE_INTELLIGENCE_LLM_MODEL=
QUOTE_INTELLIGENCE_LLM_BASE_URL=
QUOTE_INTELLIGENCE_LLM_API_KEY=
QUOTE_INTELLIGENCE_LLM_TIMEOUT_SECONDS=30

ATOMY_DEFAULT_PER_PAGE=25
ATOMY_MAX_PER_PAGE=100
ATOMY_MAX_UPLOAD_MB=50
ATOMY_MFA_DEVICE_TRUST_DAYS=30
ATOMY_APPROVAL_SLA_HOURS=48
ATOMY_APPROVAL_MAX_SNOOZE_HOURS=72
ATOMY_MIN_VENDORS_FINAL=2
ATOMY_MIN_VENDORS_PREVIEW=1
ATOMY_CONFIDENCE_THRESHOLD=0.7
ATOMY_SEED_TENANT_ID=
ATOMY_SEED_EMAIL=
ATOMY_SEED_PASSWORD=

# Feature Flags
# Projects / Tasks API (WEB lists and detail pages call these; when false, routes return 404)
FEATURE_PROJECTS_ENABLED=true
FEATURE_TASKS_ENABLED=true

# Mail / Notifications
# Log mailer keeps alpha safe by default; swap to a real transport only if staging needs outbound mail.
MAIL_MAILER=log
MAIL_HOST=smtp.alpha.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@alpha.example.com
MAIL_FROM_NAME=${APP_NAME}
MAIL_EHLO_DOMAIN=
MAIL_LOG_CHANNEL=stack
MAIL_SCHEME=
MAIL_SENDMAIL_PATH=
MAIL_URL=

# Notification provider adapters remain dormant unless the app is wired to them.
POSTMARK_API_KEY=
POSTMARK_MESSAGE_STREAM_ID=
RESEND_API_KEY=
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_STDERR_FORMATTER=
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_USERNAME="Laravel Log"
LOG_SLACK_EMOJI=:boom:
LOG_PAPERTRAIL_HANDLER=
PAPERTRAIL_URL=
PAPERTRAIL_PORT=
LOG_SYSLOG_FACILITY=LOG_USER

# OIDC
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=

# Shown in exported OpenAPI info.version (Scramble)
# API_VERSION=0.1.0
